{
  "name": "@mnemoss/openclaw-plugin",
  "version": "0.1.0",
  "description": "OpenClaw memory plugin backed by Mnemoss — ACT-R recall with spreading activation and dreaming.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "memory",
    "mnemoss",
    "act-r",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opcify/mnemoss",
    "directory": "adapters/openclaw"
  },
  "dependencies": {
    "@mnemoss/sdk": "file:../../sdks/typescript"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.24-beta.2"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    }
  }
}
