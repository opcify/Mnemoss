# Environment variables for the Mnemoss launch work.
#
# Copy this file to `.env` and fill in the real values.
# `.env` is already ignored by git (see .gitignore).
#
# Both the Makefile (`make launch-bench` / `make record-simulation`)
# and the Python CLIs (`python -m bench.launch_comparison` /
# `python -m demo.simulate`) auto-load this file.

# ─── required for `make launch-bench` (OpenAI text-embedding-3-small) ─
# Used by MnemossBackend (default OpenAIEmbedder) and RawStackBackend
# on published chart runs. Create at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ─── required for `make record-simulation` (Gemini 2.5 Flash free tier) ─
# Used by demo.llm.GeminiLLM when recording a real simulation trace.
# Free tier is generous; zero spend for weekend launch recording.
# Create at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── required for the dreaming-validation harness (bench/ablate_dreaming.py) ─
# Used for both the Consolidate LLM and the gist-quality judge LLM
# (different models pinned in bench/ablate_dreaming.toml). Get a key:
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ─── optional: hard spend cap for bench runs ─────────────────────────
# The `full` CI job uses this in .github/workflows/bench-ci.yml.
# Local runs ignore it today (the harness doesn't yet meter per-call
# cost), but setting it here costs nothing and future-proofs.
MNEMOSS_BENCH_BUDGET_USD=5
